rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /donations/{donationId} {
      allow read, write: if signedIn();
    }

    match /blood_requests/{requestId} {
      allow read, create, update: if signedIn();
      allow delete: if signedIn() && resource.data.requesterId == request.auth.uid;
    }

    match /notification_queue/{requestId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate: Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Validation Blueprints
    function isValidDonor(data) {
      return data.keys().hasAll(['userId', 'name', 'phone', 'bloodGroup', 'location', 'village', 'isReadyToDonate', 'registeredAt']) &&
             data.keys().size() >= 8 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 20 &&
             data.bloodGroup is string && data.bloodGroup.size() >= 2 && data.bloodGroup.size() <= 5 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 100 &&
             data.village is string && data.village.size() > 0 && data.village.size() <= 100 &&
             data.isReadyToDonate is bool &&
             data.userId == request.auth.uid;
    }

    function isValidDonation(data) {
      return data.keys().hasAll(['donorId', 'userId', 'date', 'hospital', 'units']) &&
             data.keys().size() >= 5 &&
             data.donorId is string &&
             data.userId == request.auth.uid &&
             data.hospital is string && data.hospital.size() > 0 && data.hospital.size() <= 100 &&
             data.units is number && data.units > 0;
    }

    // 4. Resource Specific Rules
    match /donors/{donorId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.isReadyToDonate == true;
      allow create: if isSignedIn() && isValidDonor(request.resource.data) && donorId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && isValidDonor(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    match /donations/{donationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidDonation(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidDonation(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}

{
  "entities": {
    "Donor": {
      "title": "Donor",
      "description": "Public searchable profile for a blood donor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns this profile." },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "location": { "type": "string" },
        "village": { "type": "string" },
        "lastDonationDate": { "type": "string", "format": "date-time" },
        "isReadyToDonate": { "type": "boolean" },
        "registeredAt": { "type": "number" }
      },
      "required": ["userId", "name", "phone", "bloodGroup", "location", "village"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A record of a single blood donation.",
      "type": "object",
      "properties": {
        "donorId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "hospital": { "type": "string" },
        "units": { "type": "number" }
      },
      "required": ["donorId", "userId", "date", "hospital", "units"]
    }
  },
  "firestore": {
    "/donors/{donorId}": {
      "schema": "Donor",
      "description": "Donor profiles."
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Donation logs."
    }
  }
}
